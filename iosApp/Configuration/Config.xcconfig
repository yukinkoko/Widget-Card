DEVELOPMENT_TEAM=$(TEAM_ID)

PRODUCT_NAME=designer_kmp_template
PRODUCT_BUNDLE_IDENTIFIER=jp.co.tsuqrea.wordwidget
// ホーム画面のアプリ名（PRODUCT_NAME はビルド成果物名のため据え置き）
